    "invest_military": 0.0から1.0の数値,
    "invest_welfare": 0.0から1.0の数値,
    "invest_intelligence": 0.0から1.0の数値（諜報・技術開発への投資。諜報レベルを蓄積し、諜報活動の成功率に直結する）
  },
  "diplomatic_policies": [
